{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Office 365 Mail Manager Configuration",
  "required": ["microsoft"],
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable/disable the skill"
    },
    "microsoft": {
      "type": "object",
      "required": ["clientId", "tenantId", "clientSecret", "userPrincipalName"],
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Azure App Client ID"
        },
        "tenantId": {
          "type": "string",
          "description": "Azure Tenant ID"
        },
        "clientSecret": {
          "type": "string",
          "description": "Azure App Client Secret",
          "format": "password"
        },
        "userPrincipalName": {
          "type": "string",
          "format": "email",
          "description": "Email address to manage"
        }
      }
    },
    "behavior": {
      "type": "object",
      "properties": {
        "timezone": {
          "type": "string",
          "default": "Europe/Berlin",
          "description": "Timezone for scheduling"
        },
        "checkIntervalMinutes": {
          "type": "integer",
          "default": 30,
          "minimum": 5,
          "description": "How often to check for new mails"
        },
        "maxMailsPerBatch": {
          "type": "integer",
          "default": 20,
          "description": "Maximum mails to process per batch"
        },
        "dryRun": {
          "type": "boolean",
          "default": false,
          "description": "Show actions without executing"
        }
      }
    },
    "categories": {
      "type": "object",
      "properties": {
        "important": {
          "type": "object",
          "properties": {
            "folder": {
              "type": "string",
              "default": "Wichtig"
            },
            "autoMarkRead": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "newsletter": {
          "type": "object",
          "properties": {
            "folder": {
              "type": "string",
              "default": "Newsletter"
            },
            "autoMarkRead": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "invoice": {
          "type": "object",
          "properties": {
            "folder": {
              "type": "string",
              "default": "Rechnungen"
            },
            "forwardTo": {
              "type": "string",
              "format": "email",
              "description": "Email to forward invoices to"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "channel": {
          "type": "string",
          "enum": ["whatsapp", "telegram", "signal", "bluebubbles"],
          "description": "Where to send summaries"
        },
        "target": {
          "type": "string",
          "description": "Phone number or chat ID"
        },
        "time": {
          "type": "string",
          "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$",
          "description": "Daily summary time (HH:MM)"
        }
      }
    }
  }
}
